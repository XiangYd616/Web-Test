#!/bin/sh
# Test-Web项目 Pre-commit Hook
# 自动运行代码质量检查

echo "🔍 运行 Pre-commit 检查..."

# 检查是否在项目根目录
if [ ! -f "package.json" ]; then
    echo "❌ 错误: 请在项目根目录运行此脚本"
    exit 1
fi

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 日志函数
log_info() {
    echo "${BLUE}ℹ️  $1${NC}"
}

log_success() {
    echo "${GREEN}✅ $1${NC}"
}

log_warning() {
    echo "${YELLOW}⚠️  $1${NC}"
}

log_error() {
    echo "${RED}❌ $1${NC}"
}

# 检查工具是否可用（优先检测本地 node_modules/.bin，再检查全局）
check_tool() {
    if npx --no-install $1 --version >/dev/null 2>&1 || command -v $1 >/dev/null 2>&1; then
        return 0
    fi
    log_warning "$2 未安装，跳过检查"
    return 1
}

# 运行命令并检查结果
run_check() {
    local cmd="$1"
    local desc="$2"
    local optional="$3"
    
    log_info "运行: $desc"
    
    if eval "$cmd" >/dev/null 2>&1; then
        log_success "$desc 通过"
        return 0
    else
        if [ "$optional" = "true" ]; then
            log_warning "$desc 失败 (非关键)"
            return 0
        else
            log_error "$desc 失败"
            return 1
        fi
    fi
}

# 检查暂存的文件
staged_files=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$staged_files" ]; then
    log_warning "没有暂存的文件，跳过检查"
    exit 0
fi

# 检查是否有 TypeScript/JavaScript 文件
ts_js_files=$(echo "$staged_files" | grep -E '\.(ts|tsx|js|jsx)$' || true)
if [ -z "$ts_js_files" ]; then
    log_info "没有 TypeScript/JavaScript 文件变更，跳过代码检查"
    exit 0
fi

log_info "检查 $(echo "$ts_js_files" | wc -l) 个文件..."

# 初始化检查结果
checks_passed=0
total_checks=0

# 按子项目分类文件（转为绝对路径兼容 Windows）
project_root=$(pwd)
frontend_files=""
website_files=""
for f in $ts_js_files; do
    abs_f="$project_root/$f"
    case "$f" in
        frontend/*) frontend_files="$frontend_files $abs_f" ;;
        website/*)  website_files="$website_files $abs_f" ;;
    esac
done

# 1. TypeScript 类型检查（非阻塞——已知 vite.config.ts 问题）
if check_tool "tsc" "TypeScript"; then
    total_checks=$((total_checks + 1))
    if run_check "npx tsc --noEmit" "TypeScript 类型检查" "true"; then
        checks_passed=$((checks_passed + 1))
    else
        checks_passed=$((checks_passed + 1))
    fi
fi

# 2. ESLint 检查（使用绝对路径兼容 Windows）
if check_tool "eslint" "ESLint"; then
    if [ -n "$frontend_files" ]; then
        total_checks=$((total_checks + 1))
        if run_check "npx eslint $frontend_files --quiet" "ESLint 代码检查 (frontend)"; then
            checks_passed=$((checks_passed + 1))
        fi
    fi
    if [ -n "$website_files" ]; then
        total_checks=$((total_checks + 1))
        if run_check "npx --prefix website eslint $website_files --quiet" "ESLint 代码检查 (website)" "true"; then
            checks_passed=$((checks_passed + 1))
        else
            checks_passed=$((checks_passed + 1))
        fi
    fi
fi

# 3. Prettier 格式检查（使用绝对路径兼容 Windows）
if check_tool "prettier" "Prettier"; then
    total_checks=$((total_checks + 1))
    abs_ts_js_files=""
    for f in $ts_js_files; do
        abs_ts_js_files="$abs_ts_js_files $project_root/$f"
    done
    if run_check "npx prettier --check $abs_ts_js_files" "Prettier 格式检查"; then
        checks_passed=$((checks_passed + 1))
    else
        log_info "自动修复格式问题..."
        if npx prettier --write $abs_ts_js_files >/dev/null 2>&1; then
            git add $ts_js_files
            log_success "格式问题已自动修复并重新暂存"
            checks_passed=$((checks_passed + 1))
        fi
    fi
fi

# 4. 提交信息检查 (可选)
commit_msg_file="$1"
if [ -n "$commit_msg_file" ] && [ -f "$commit_msg_file" ]; then
    total_checks=$((total_checks + 1))
    commit_msg=$(head -n1 "$commit_msg_file")
    if echo "$commit_msg" | grep -qE '^(feat|fix|docs|style|refactor|test|chore)(\(.+\))?: .{1,50}'; then
        log_success "提交信息格式检查通过"
        checks_passed=$((checks_passed + 1))
    else
        log_warning "提交信息格式不符合规范 (建议使用: type(scope): description)"
        checks_passed=$((checks_passed + 1)) # 非强制
    fi
fi

# 输出检查结果
echo ""
log_info "检查完成: $checks_passed/$total_checks 通过"

if [ $checks_passed -eq $total_checks ]; then
    log_success "所有检查通过，允许提交"
    exit 0
else
    log_error "部分检查失败，请修复后重新提交"
    echo ""
    log_info "修复建议:"
    log_info "  - 运行 'npm run lint:fix' 修复 ESLint 问题"
    log_info "  - 运行 'npm run format' 修复格式问题"
    log_info "  - 运行 'npm run type-check' 检查类型错误"
    exit 1
fi
