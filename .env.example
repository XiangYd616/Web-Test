# ===========================================
# Test Web App - 前端环境配置模板
# ===========================================
# 复制此文件为 .env 并根据实际环境修改配置值
# 此文件主要用于前端开发配置
# 后端配置请查看 server/.env.example

# ===========================================
# 前端开发服务器配置
# ===========================================
VITE_DEV_PORT=5174
# /proxy 前缀的请求代理目标（留空则禁用代理）
VITE_PROXY_TARGET=
VITE_API_URL=http://localhost:3001/api
VITE_WS_URL=ws://localhost:3001

# ===========================================
# Supabase 云端认证（必填，用于用户注册/登录）
# ===========================================
# 从 Supabase Dashboard → Settings → API 获取
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ===========================================
# 应用基本信息
# ===========================================
VITE_APP_NAME=Test Web App
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=企业级网站测试平台

# ===========================================
# 前端功能开关
# ===========================================
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_DEBUG=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PWA=true

# ===========================================
# 前端安全配置
# ===========================================
VITE_MAX_LOGIN_ATTEMPTS=5
VITE_LOCKOUT_DURATION=15
VITE_SESSION_TIMEOUT=86400000
VITE_API_RATE_LIMIT=100
VITE_ADMIN_API_RATE_LIMIT=50

# ===========================================
# 文件上传配置 (前端限制)
# ===========================================
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,txt

# ===========================================
# 测试配置 (前端)
# ===========================================
VITE_DEFAULT_TEST_TIMEOUT=300000
VITE_MAX_CONCURRENT_TESTS=5

# ===========================================
# 第三方服务API配置 (前端使用)
# ===========================================
# 注意：这些API密钥仅用于前端，敏感配置请放在server/.env

# Google APIs (前端PageSpeed测试)
VITE_GOOGLE_PAGESPEED_API_KEY=your_google_api_key_here
VITE_GOOGLE_PROJECT_ID=your_project_id

# 第三方测试服务 (前端配置)
VITE_GTMETRIX_API_KEY=your_gtmetrix_api_key
VITE_WEBPAGETEST_API_KEY=your_webpagetest_api_key

# ===========================================
# 开发模式配置
# ===========================================
# 模拟数据配置 (开发环境)
VITE_USE_MOCK_DATA=false
VITE_MOCK_API_DELAY=1000
VITE_ENABLE_OFFLINE_MODE=false

# ===========================================
# 监控和分析 (前端)
# ===========================================
# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=your_ga_measurement_id

# Sentry错误监控
VITE_SENTRY_DSN=your_sentry_dsn

# ===========================================
# 开发工具配置
# ===========================================
VITE_DEV_TOOLS=true
VITE_MOCK_DELAY=1000

# ===========================================
# 生产环境配置示例
# ===========================================
# 生产环境请修改以下配置：
# VITE_API_URL=https://api.yourdomain.com/api
# VITE_WS_URL=wss://api.yourdomain.com
# VITE_ENABLE_MOCK_DATA=false
# VITE_ENABLE_DEBUG=false
# VITE_ENABLE_ANALYTICS=true
# VITE_GOOGLE_ANALYTICS_ID=your_real_ga_id
# VITE_SENTRY_DSN=your_real_sentry_dsn

# ===========================================
# 重要提示
# ===========================================
# 1. 此文件仅包含前端配置
# 2. 后端配置请查看 server/.env.example
# 3. 所有以 VITE_ 开头的变量会被打包到前端代码中
# 4. 敏感信息请放在后端配置中
# 5. 生产环境请修改所有默认值
# 6. 不要将包含真实密钥的 .env 文件提交到版本控制

# ===========================================
# 相关文档
# ===========================================
# 环境配置指南: docs/ENV_CONFIGURATION_GUIDE.md
# 项目结构说明: docs/PROJECT_STRUCTURE.md
# 数据库配置: docs/DATABASE_COMPLETE_GUIDE.md

# ===========================================
# 后端核心配置
# ===========================================
# 运行环境 (development/production)
NODE_ENV=development

# 服务器端口号
PORT=3001

# ===========================================
# 数据库配置（SQLite）
# ===========================================
# SQLite 数据文件目录（默认 ./data）
SQLITE_DATA_DIR=./data
# SQLite 数据库文件名（默认 testweb.db）
SQLITE_DB_NAME=testweb.db
# 开发环境查询日志
DB_LOG_QUERIES=false

# ===========================================
# 认证与安全
# ===========================================
# Supabase JWT Secret（从 Supabase Dashboard → Settings → API → JWT Secret 获取）
# 后端用此密钥验证前端传来的 Supabase access_token
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# JWT 令牌密钥（本地模式/桌面模式使用，生产环境务必修改！）
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# 会话密钥
SESSION_SECRET=your-session-secret-here

# WebSocket 加密密钥（可选）
WS_ENCRYPTION_KEY=your-strong-secret

# CORS 允许的源
CORS_ORIGIN=http://localhost:5174

# ===========================================
# OAuth2 第三方登录（可选，按需配置）
# ===========================================
# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/oauth/google/callback

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3001/api/oauth/github/callback

# Facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3001/api/oauth/facebook/callback

# Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/oauth/microsoft/callback

# ===========================================
# 邮件服务 SMTP（可选，用于密码重置/通知）
# ===========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@testweb.com
EMAIL_FROM_NAME=Test-Web Platform

# ===========================================
# 通知渠道（可选）
# ===========================================
# 告警通知渠道（逗号分隔: email,slack）
ALERT_CHANNELS=email
# 告警邮件接收人
ALERT_EMAIL_TO=
# Slack Webhook URL
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=

# ===========================================
# 安全事件日志
# ===========================================
# 是否将安全事件写入数据库（默认仅写日志文件）
SECURITY_EVENT_DB_ENABLED=false

# ===========================================
# 认证限流
# ===========================================
EMAIL_VERIFICATION_WINDOW_MS=900000
EMAIL_VERIFICATION_MAX_ATTEMPTS=10
RESEND_VERIFICATION_WINDOW_MS=3600000
RESEND_VERIFICATION_MAX_ATTEMPTS=5

# ===========================================
# 文件上传
# ===========================================
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,txt
UPLOAD_DESTINATION=uploads

# ===========================================
# 测试引擎配置
# ===========================================
# HTTP 请求超时（毫秒）
REQUEST_TIMEOUT=30000

# ===========================================
# GeoIP（可选，用于登录地域检测）
# ===========================================
MAXMIND_LICENSE_KEY=

# ===========================================
# 日志
# ===========================================
LOG_LEVEL=info
