{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "..",
    "outDir": "dist",
    "allowJs": true,
    "checkJs": false,
    "sourceMap": true,
    "declaration": false,
    "noImplicitReturns": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true
  },
  "include": [
    "**/*.js",
    "**/*.ts",
    "**/*.d.ts",
    "../shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "server.js",
    "**/*.test.js",
    "**/*.spec.js",
    "**/__tests__/**",
    "skills/**",
    "../shared/skills/**"
  ]
}
