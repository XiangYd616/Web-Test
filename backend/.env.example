# ==========================================
# Test-Web 本地 API 测试工具 - 后端配置模板
# ==========================================
# 复制此文件为 .env 并根据需要修改
# 纯本地模式：SQLite 存储，无需外部数据库/Redis/云服务

# ==========================================
# 基本服务配置
# ==========================================
PORT=3001
NODE_ENV=development
HOST=localhost

# ==========================================
# 数据库配置 (SQLite)
# ==========================================
SQLITE_DATA_DIR=./data
SQLITE_DB_NAME=testweb.db

# ==========================================
# CORS配置
# ==========================================
CORS_ORIGIN=http://localhost:5174,http://localhost:3000

# ==========================================
# 认证配置
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-here-please-change
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ==========================================
# 文件上传配置
# ==========================================
MAX_FILE_SIZE=50mb
UPLOAD_DIR=uploads
TEMP_DIR=temp

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=info
LOG_DIR=logs

# ==========================================
# 速率限制配置
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# ==========================================
# 测试引擎配置
# ==========================================
TEST_TIMEOUT=30000
TEST_MAX_CONCURRENT=5

# ==========================================
# 开发环境配置
# ==========================================
DEBUG_SQL=false
DEBUG_ROUTES=false
