{
  "name": "test-web-app",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "description": "集成压力测试、内容检测、兼容性测试的跨平台桌面应用",
  "author": {
    "name": "Test Web App Team",
    "email": "1823170057@qq.com"
  },
  "main": "electron/main.cjs",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend\"",
    "frontend": "cross-env VITE_DEV_PORT=5174 vite --host",
    "backend": "cross-env npm run --prefix backend start",
    "backend:dev": "cross-env npm run --prefix backend dev",
    "build": "cross-env NODE_ENV=production vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "type-check:backend": "npm run --prefix backend type-check",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "electron:start": "electron .",
    "electron:dev": "concurrently \"npm run -w . frontend\" \"wait-on http://localhost:5174 && cross-env ELECTRON_IS_DEV=1 ELECTRON_DEV_SERVER_URL=http://localhost:5174 electron .\"",
    "electron:backend": "node tools/electron/buildBackend.mjs",
    "electron:build": "cross-env NODE_ENV=production ELECTRON=true vite build && node tools/electron/buildBackend.mjs && node tools/electron/build.mjs && cd tools/electron && npx electron-builder --win",
    "electron:dist": "cross-env NODE_ENV=production ELECTRON=true vite build && node tools/electron/buildBackend.mjs && node tools/electron/build.mjs && cd tools/electron && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ npx electron-builder",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "format": "prettier --write \"frontend/**/*.{ts,tsx,js,jsx,css,md}\"",
    "deps:update": "npm update",
    "ci:check": "npm run type-check && npm run lint && npm run build",
    "clean": "rimraf dist dist-electron node_modules/.cache",
    "website": "npm run --prefix website dev",
    "website:build": "npm run --prefix website build",
    "clean:all": "rimraf dist dist-electron node_modules",
    "version:sync": "node scripts/sync-version.mjs",
    "version:patch": "node scripts/sync-version.mjs patch",
    "version:minor": "node scripts/sync-version.mjs minor",
    "version:major": "node scripts/sync-version.mjs major",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.95.3",
    "@types/qrcode": "^1.5.5",
    "ahooks": "^3.9.4",
    "axios": "^1.11.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "i18next": "^25.8.0",
    "jwks-rsa": "^3.2.2",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.544.0",
    "next-themes": "^0.4.6",
    "pg": "^8.16.2",
    "pixelmatch": "^7.1.0",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-datepicker": "^8.7.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^6.20.1",
    "recharts": "^2.15.3",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@storybook/addon-actions": "8.6.15",
    "@storybook/addon-controls": "8.6.15",
    "@storybook/addon-docs": "8.6.15",
    "@storybook/addon-essentials": "8.6.15",
    "@storybook/addon-interactions": "8.6.15",
    "@storybook/addon-links": "8.6.15",
    "@storybook/addon-viewport": "8.6.15",
    "@storybook/react": "8.6.15",
    "@storybook/react-vite": "8.6.15",
    "@storybook/test": "8.6.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.20",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^4.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "connect-history-api-fallback": "^2.0.0",
    "cross-env": "^7.0.3",
    "electron": "^32.2.6",
    "electron-builder": "^25.1.8",
    "eslint": "^9.38.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "rimraf": "^5.0.5",
    "sass-embedded": "^1.97.3",
    "storybook": "8.6.15",
    "tailwindcss": "^3.4.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.testweb.app",
    "productName": "Test Web App",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!node_modules/.vite"
    ],
    "includeSubNodeModules": true,
    "buildDependenciesFromSource": false,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "your-username",
      "repo": "test-web-app"
    }
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.25.5"
  },
  "resolutions": {
    "glob": "^10.3.0",
    "rimraf": "^5.0.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "inflight": "^1.0.6",
    "@types/node": "^20.10.0"
  }
}
